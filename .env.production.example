# Copy to .env and fill in before deploy
# cp .env.production.example .env

PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# REQUIRED — long random string for /admin login
ADMIN_TOKEN=

# SET data source: mock | delay | realtime
SET_MODE=mock
SET_API_KEY=

# SQLite path (Docker uses /data/lottery.db via volume)
DB_PATH=./server/data/lottery.db
UPLOAD_DIR=./server/data/uploads

# CORS — comma-separated origins, or leave empty when frontend served same-origin
CORS_ORIGIN=

# For Caddy HTTPS profile
DOMAIN=yourdomain.com

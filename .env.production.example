# Copy to .env and fill in before deploy
# cp .env.production.example .env

PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# REQUIRED — long random string for /admin login
ADMIN_TOKEN=

# SET data source: public | mock | delay | realtime
SET_MODE=mock
# SET_API_KEY is a token string, NOT a URL.
SET_API_KEY=

# SQLite path (Docker uses /data/lottery.db via volume)
DB_PATH=./server/data/lottery.db
UPLOAD_DIR=./server/data/uploads

# CORS — comma-separated origins, or leave empty when frontend served same-origin
# Supports wildcard entries like https://*.vercel.app
CORS_ORIGIN=

# Supabase (optional for cloud DB + storage)
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbG...
# SUPABASE_STORAGE_BUCKET=assets

# For Caddy HTTPS profile
DOMAIN=yourdomain.com

PORT=3001
ADMIN_TOKEN=change-me-to-a-long-random-string

# SET data: public (free via api.thaistock2d.com/live) | mock (demo) | delay | realtime (needs SET_API_KEY token)
SET_MODE=public
SEED_DATA=none
# SET_API_KEY is a token string, NOT a URL.
SET_API_KEY=
# When public SET endpoints are blocked, use temporary mock index instead of blank UI.
SET_FALLBACK_ON_ERROR=true

DB_PATH=./data/lottery.db
UPLOAD_DIR=./data/uploads

# Supabase — cloud DB + image storage (optional locally)
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbG...
# SUPABASE_STORAGE_BUCKET=assets

CORS_ORIGIN=http://localhost:5173
